      "Bash(curl -s http://localhost:8081)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:8081)",
      "Bash(npx tsc:*)",
      "Bash(powershell -Command \"Get-NetTCPConnection -State Listen | Where-Object {$_LocalPort -in @\\(8081,8082,5173,3000,3001\\)} | Select-Object LocalPort,State\")",
